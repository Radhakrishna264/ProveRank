          <div onClick={e=>e.stopPropagation()} style={{width:'100%',maxWidth:420,height:'100%',overflowY:'auto' as any,background:CRD,borderLeft:`1px solid ${BOR}`,padding:20,boxSizing:'border-box' as any}}>
