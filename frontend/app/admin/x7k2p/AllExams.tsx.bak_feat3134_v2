              <div>
                <label style={lbl}>Custom Instructions</label>
                <textarea value={editForm.customInstructions} onChange={e=>setEditForm((f:any)=>({...f,customInstructions:e.target.value}))} rows={3} style={{...inp,resize:'vertical' as any}}/>
