            <div style={{ fontSize:12, color:C.dim, lineHeight:1.7 }}>{card.sub}</div>
            <div style={{ marginTop:20, fontSize:12, color:card.accent, fontWeight:700 }}>Get Started →</div>
          </div>
        ))}
