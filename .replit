run = "export PATH=/nix/store/9g2w08zkmj60d97bc0ci62w6msfdi9av-nodejs-14.18.3/bin:$PATH && cd /home/runner/workspace/frontend && npm run dev"
modules = ["nodejs-20"]

[[ports]]
localPort = 3000
externalPort = 3000

[[ports]]
localPort = 5904
externalPort = 3000

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node src/index.js"
waitForPort = 3000

[workflows.workflow.metadata]
outputType = "console"
